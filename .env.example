# ============================================================
# Disability-Assist Environment Configuration
# Copy to .env and fill in required values
# ============================================================

# --- Cloud Provider Configuration (Required) ---
STT_PROVIDER=deepgram
STT_API_KEY=
LLM_PROVIDER=anthropic
LLM_API_KEY=
LLM_MODEL=claude-haiku-4-5
TTS_PROVIDER=azure
TTS_API_KEY=
TTS_REGION=

# --- Database (Required) ---
DATABASE_URL=sqlite:///./assist.db

# --- Vector Store (Optional) ---
QDRANT_URL=
QDRANT_API_KEY=

# --- Home Assistant (Optional) ---
HOME_ASSISTANT_URL=
HOME_ASSISTANT_TOKEN=

# --- Device Configuration (For RPi5) ---
HOST_SUFFIX_ID=
SSH_USERNAME=admin

# --- Application Settings ---
DEBUG=false
LOG_LEVEL=INFO

# --- Security ---
SECRET_KEY=
JWT_ALGORITHM=HS256
JWT_EXPIRY_HOURS=24

# --- Cloud Operating Limits ---
# Target: CAD 8-15 per user per month
MAX_STT_REQUESTS_PER_HOUR=120
MAX_LLM_REQUESTS_PER_HOUR=120
MAX_TTS_REQUESTS_PER_HOUR=120
